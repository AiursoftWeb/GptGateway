{
  "ConnectionStrings": {
    "AllowCache": "True",
    "DbType": "InMemory",
    "DefaultConnection": "TestDb"
  },
  "Storage": {
    "Path": "/tmp/test-data"
  },
  "ApiKey": "test-api-key",
  "BingSearchAPIKey": "",

  "DefaultIncomingModel": "qwen3:32b-q8_0",
  "SupportedModels": [
    {
      "Name": "qwen3:32b-q8_0",
      "Description": "Qwen3 32B",
      "UnderlyingProvider": "Ollama",
      "UnderlyingModel": "qwen3:32b-q8_0"
    },
    {
      "Name": "test-thinking-model",
      "Description": "Thinking Model",
      "UnderlyingProvider": "Ollama",
      "UnderlyingModel": "ollama-thinking",
      "Thinking": true
    },
    {
      "Name": "test-options-model",
      "Description": "Options Model",
      "UnderlyingProvider": "Ollama",
      "UnderlyingModel": "ollama-options",
      "Options": {
        "NumCtx": 4096,
        "Temperature": 0.1,
        "TopP": 0.2,
        "TopK": 10
      }
    }
  ],

  "EmbeddingModels": [
    {
      "Name": "test-embedding",
      "Description": "Test Embedding Model",
      "UnderlyingModel": "test-embedding-underlying",
      "Options": {
        "NumCtx": 8192
      }
    }
  ],

  "Underlyings": {
    "OpenAI": {
      "Token": "test",
      "InstanceUrl": "https://api.openai.com/"
    },
    "DeepSeek":{
      "Token": "test",
      "Instance": "https://api.deepseek.com/"
    },
    "Ollama": {
      "Instance": "http://localhost:11434/"
    }
  },

  "Clickhouse": {
    "Enabled": false,
    "ConnectionString": "Host=localhost;Protocol=http;Port=8123;User=default;Password=clickhouse_password;Database=default"
  },

  "Logging": {
